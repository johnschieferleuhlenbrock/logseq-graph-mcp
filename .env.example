# Required unless you pass --root to the CLI.
LOGSEQ_ROOT=/path/to/logseq

# Safety defaults for local agent sessions.
LOGSEQ_READONLY=0
LOGSEQ_WRITE_MODE=intent
LOGSEQ_VALIDATE_SCHEMA=block
LOGSEQ_DISALLOW_FORCE=0
LOGSEQ_VALIDATE_LINKS=block
LOGSEQ_GIT_GUARD=strict
LOGSEQ_GIT_COMMIT_AUTHOR="Logseq MCP Guard <logseq-mcp@localhost>"
LOGSEQ_GIT_GUARD_IGNORE_DIRS=
LOGSEQ_GIT_MAX_CHANGED_FILES=25
LOGSEQ_GIT_MAX_DELETED_FILES=0

# Runtime/cache behavior.
LOGSEQ_CACHE_DIR=
LOGSEQ_WATCH=1
LOGSEQ_LOCK_TIMEOUT_MS=5000

# Response and search guardrails.
LOGSEQ_MAX_RESPONSE_BYTES=500000
LOGSEQ_MAX_REGEX_LEN=500
LOGSEQ_REGEX_TIMEOUT_S=2
LOGSEQ_MAX_SEARCH_LINE=10000
LOGSEQ_REGEX_ENGINE=auto
LOGSEQ_ALLOW_EXTERNAL_REGEN=0
LOGSEQ_PYTHON=python3
