{
  "name": "logseq-graph-mcp",
  "version": "0.1.3",
  "description": "Local-only stdio MCP server for safe agent access to any Logseq markdown graph.",
  "type": "module",
  "homepage": "https://github.com/johnschieferleuhlenbrock/logseq-graph-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnschieferleuhlenbrock/logseq-graph-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/johnschieferleuhlenbrock/logseq-graph-mcp/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "logseq-graph-mcp": "dist/cli.js",
    "logseq-mcp-server": "dist/cli.js"
  },
  "files": [
    "dist",
    ".env.example",
    "install.sh",
    "examples",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm test && npm run pack:dry-run",
    "clean": "rm -rf dist",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run clean && npm run build",
    "sbom": "npm sbom --sbom-format spdx > sbom.spdx.json && npm sbom --sbom-format cyclonedx > sbom.cyclonedx.json",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test tests/*.test.js"
  },
  "keywords": [
    "logseq",
    "mcp",
    "model-context-protocol",
    "markdown",
    "knowledge-graph",
    "local-first"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "optionalDependencies": {
    "re2": "1.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.8.0"
  },
  "license": "MIT"
}
